<UserControl
    x:Class="TelegraphGallery.Dialogs.UploadSuccessDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:TelegraphGallery.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="460"
    Height="150"
    d:DataContext="{d:DesignInstance dialogs:UploadSuccessDialogViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="Icon" Value="{StaticResource SuccessIcon}" />
            <Setter Property="ResizeMode" Value="NoResize" />
            <Setter Property="SizeToContent" Value="WidthAndHeight" />
        </Style>
    </prism:Dialog.WindowStyle>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="16"
            FontWeight="Bold"
            Text="Upload Complete" />

        <DockPanel Grid.Row="1" Margin="0,0,0,12">

            <TextBlock
                Margin="0,0,4,0"
                VerticalAlignment="Center"
                TextTrimming="CharacterEllipsis">
                <Hyperlink Command="{Binding OpenUrlCommand}">
                    <Run Text="{Binding Url, Mode=OneWay}" />
                </Hyperlink>
            </TextBlock>
        </DockPanel>
        <DockPanel
            Grid.Row="3"
            HorizontalAlignment="Right"
            VerticalAlignment="Center">
            <Button
                Width="{Binding ActualWidth, ElementName=Button, Mode=OneWay}"
                HorizontalAlignment="Right"
                Command="{Binding CloseCommand}"
                Content="OK" />
            <Button
                x:Name="Button"
                Margin="10,0,0,0"
                Padding="12,4"
                Command="{Binding CopyUrlCommand}"
                Content="Copy URL"
                DockPanel.Dock="Right"
                ToolTip="Copy URL to clipboard" />
        </DockPanel>
    </Grid>
</UserControl>
