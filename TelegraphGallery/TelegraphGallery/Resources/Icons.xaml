<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Main window icon: landscape photo in a blue card  -->
    <DrawingImage x:Key="AppIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!--  Background: rounded blue card  -->
                <GeometryDrawing Brush="#1976D2">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry
                            RadiusX="3"
                            RadiusY="3"
                            Rect="0,0,32,32" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!--  Inner frame  -->
                <GeometryDrawing Brush="#BBDEFB">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="3,3,26,26" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!--  Sky gradient area  -->
                <GeometryDrawing Brush="#64B5F6">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="3,3,26,18" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!--  Sun  -->
                <GeometryDrawing Brush="#FFD54F">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry
                            Center="22,10"
                            RadiusX="3.5"
                            RadiusY="3.5" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!--  Mountains  -->
                <GeometryDrawing Brush="#43A047">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M3,29 L11,14 L19,29 Z" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#2E7D32">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M15,29 L23,17 L29,29 Z" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!--  Success icon: green circle with white checkmark  -->
    <DrawingImage x:Key="SuccessIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#4CAF50">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry
                            Center="16,16"
                            RadiusX="16"
                            RadiusY="16" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen
                            Brush="White"
                            EndLineCap="Round"
                            LineJoin="Round"
                            StartLineCap="Round"
                            Thickness="3" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M8,16 L14,22 L24,10" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
