<UserControl
    x:Class="TelegraphGallery.Views.ToolbarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:TelegraphGallery.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:TelegraphGallery.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:ToolbarViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:NullOrEmptyToCollapsedConverter x:Key="NullOrEmptyToCollapsedConverter" />
    </UserControl.Resources>
    <ToolBarTray>
        <ToolBar Band="1" BandIndex="1">
            <Button
                Margin="2"
                Padding="8,4"
                Command="{Binding OpenFolderCommand}"
                Content="Open Folder" />
            <Button
                Margin="2"
                Padding="8,4"
                Command="{Binding UploadAllCommand}"
                Content="Upload All" />
            <Button
                Margin="2"
                Padding="8,4"
                Command="{Binding CancelUploadCommand}"
                Content="Cancel" />
            <Separator />
            <Button
                Margin="2"
                Padding="8,4"
                Command="{Binding FindDuplicatesCommand}"
                Content="Find Duplicates" />
            <Button
                Margin="2"
                Padding="8,4"
                Command="{Binding ClearCacheCommand}"
                Content="Clear Cache" />
            <Separator />

            <TextBlock
                Margin="4,0"
                VerticalAlignment="Center"
                Text="Sort:" />
            <ComboBox
                Width="120"
                Margin="2"
                ItemsSource="{Binding SortModes}"
                SelectedItem="{Binding SelectedSortMode}" />
            <Separator />
            <TextBlock
                Margin="4,0"
                VerticalAlignment="Center"
                Text="Thumb Size:" />
            <Slider
                Width="150"
                Margin="2"
                VerticalAlignment="Center"
                IsSnapToTickEnabled="True"
                Maximum="400"
                Minimum="80"
                TickFrequency="10"
                Value="{Binding ThumbnailSize}" />
            <TextBlock
                Margin="4,0"
                VerticalAlignment="Center"
                Text="{Binding ThumbnailSize, StringFormat={}{0}px}" />
            <Separator Margin="50,2,2,2" />

            <Button
                Margin="2"
                Padding="8,4"
                Command="{Binding ToggleSettingsCommand}"
                Content="Settings" />

            <Separator Visibility="{Binding LastResultUrl, Converter={StaticResource NullOrEmptyToCollapsedConverter}}" />
            <TextBlock
                Margin="4,0"
                VerticalAlignment="Center"
                Visibility="{Binding LastResultUrl, Converter={StaticResource NullOrEmptyToCollapsedConverter}}">
                <Hyperlink Command="{Binding OpenResultUrlCommand}">
                    <Run Text="{Binding LastResultUrl, Mode=OneWay}" />
                </Hyperlink>
            </TextBlock>
            <Button
                Margin="2"
                Padding="8,4"
                Command="{Binding CopyResultUrlCommand}"
                Content="Copy"
                ToolTip="Copy result URL to clipboard"
                Visibility="{Binding LastResultUrl, Converter={StaticResource NullOrEmptyToCollapsedConverter}}" />

        </ToolBar>
    </ToolBarTray>
</UserControl>
